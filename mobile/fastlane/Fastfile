default_platform(:android)

def play_json_key_path
  key_path = File.expand_path("google-play-service-account.json", __dir__)
  credentials = ENV["GCLOUD_SERVICE_ACCOUNT_CREDENTIALS"] || ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_CREDENTIALS"]

  if credentials && !credentials.strip.empty?
    File.write(key_path, credentials)
  end

  unless File.exist?(key_path)
    UI.user_error!(
      "Google Play credentials missing. Set GCLOUD_SERVICE_ACCOUNT_CREDENTIALS in Codemagic or place google-play-service-account.json in mobile/fastlane locally."
    )
  end

  key_path
end

platform :android do
  desc "Upload Play Store listing, icon and screenshots without uploading a build"
  lane :upload_store_listing do
    upload_to_play_store(
      package_name: ENV.fetch("ANDROID_PACKAGE_NAME", "com.denkma.app"),
      json_key: play_json_key_path,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_changelogs: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )
  end

  desc "Upload the release AAB to a Google Play track"
  lane :deploy_internal do
    upload_to_play_store(
      package_name: ENV.fetch("ANDROID_PACKAGE_NAME", "com.denkma.app"),
      json_key: play_json_key_path,
      aab: ENV.fetch("ANDROID_AAB_PATH", "build/app/outputs/bundle/release/app-release.aab"),
      track: ENV.fetch("GOOGLE_PLAY_TRACK", "internal"),
      release_status: ENV.fetch("GOOGLE_PLAY_RELEASE_STATUS", "draft"),
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
