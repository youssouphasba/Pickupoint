# App
APP_ENV=development
DEBUG=true
BASE_URL=http://localhost:8001
PUBLIC_SITE_URL=https://denkma.com

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=Pickupoint

# JWT
JWT_SECRET=changeme_minimum_32_chars_here_please
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP — Firebase Phone Auth gère l'envoi SMS (SDK côté mobile, aucun provider backend)

# WhatsApp Cloud API (Meta) — notifications proactives aux clients
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Pricing defaults (XOF)
BASE_RELAY_TO_RELAY=700.0
BASE_RELAY_TO_HOME=1100.0
BASE_HOME_TO_RELAY=900.0
BASE_HOME_TO_HOME=1300.0
PRICE_PER_KM=100.0
PRICE_PER_KG=100.0
FREE_WEIGHT_KG=2.0
MIN_PRICE=700.0
EXPRESS_MULTIPLIER=1.30
NIGHT_MULTIPLIER=1.20
DEFAULT_DISTANCE_KM=8.0

# Commission splits
PLATFORM_RATE=0.15
RELAY_RATE=0.15
DRIVER_RATE=0.70
